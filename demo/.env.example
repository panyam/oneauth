# PostgreSQL
POSTGRES_PASSWORD=oneauth-demo-pass

# Admin API key for host registration
ADMIN_API_KEY=demo-admin-key-12345

# JWT secret for oneauth-server browser sessions
JWT_SECRET_KEY=demo-jwt-secret-key-change-me

# Master key for encrypting HS256 client secrets at rest (AES-256-GCM).
# Must be a 64-character hex string (32 bytes). Generate with: openssl rand -hex 32
# All services sharing the same KeyStore DB must use the same key.
ONEAUTH_MASTER_KEY=deadbeefdeadbeefdeadbeefdeadbeefdeadbeefdeadbeefdeadbeefdeadbeef
