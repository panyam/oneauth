# If you prefer the allow list template instead of the deny list, see community template:
# https://github.com/github/gitignore/blob/main/community/Golang/Go.AllowList.gitignore
#
# Binaries for programs and plugins
*.exe
*.exe~
*.dll
*.so
*.dylib

# Test binary, built with `go test -c`
*.test

# Output of the go coverage tool, specifically when used with LiteIDE
*.out

# Dependency directories (remove the comment below to include it)
# vendor/

# Go workspace file

# env file
.env

# Python / integration tests
.venv/
__pycache__/
.pytest_cache/

# Build output
build/

# Test report logs (HTML report can be checked in explicitly)
# test-reports/run.log

# Demo data (devloop local runs)
demo/data/

# GAE
.gcloudignore
.playwright-mcp/
cmd/oneauth-server/oneauth-server
# Built binaries from examples and cmd
/rar-test-issuer
/01-client-credentials
/02-resource-token-hs256
/03-resource-token-rs256-jwks
/04-discovery
/05-introspection
/06-dynamic-client-registration
/07-client-sdk
/08-rich-authorization-requests
/09-key-rotation
/10-security
