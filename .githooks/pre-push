#!/bin/sh
# Pre-push hook for oneauth.
#
# Runs the test suite before pushing. Skips the test stage if the only
# files changed in the commits being pushed are test reports
# (test-reports/*) — those artifacts are regenerated by `make testall`
# and don't affect source behavior.
#
# Installed via `make setup-hooks` (git config core.hooksPath .githooks).

set -e
cd "$(git rev-parse --show-toplevel)"

# Determine the commit range being pushed. Prefer @{upstream}; fall back to
# origin/main; otherwise run the full check.
range=""
if git rev-parse --abbrev-ref --symbolic-full-name '@{upstream}' >/dev/null 2>&1; then
    range="@{upstream}..HEAD"
elif git rev-parse --verify origin/main >/dev/null 2>&1; then
    range="origin/main..HEAD"
fi

changed=""
if [ -n "$range" ]; then
    changed="$(git diff --name-only "$range" 2>/dev/null || true)"
fi

needs_tests=1
if [ -n "$changed" ]; then
    all_skip=1
    for f in $changed; do
        case "$f" in
            test-reports/*)
                ;;
            *)
                all_skip=0
                break
                ;;
        esac
    done
    if [ $all_skip -eq 1 ]; then
        needs_tests=0
    fi
fi

if [ $needs_tests -eq 0 ]; then
    echo "pre-push: only test-report changes detected, skipping test run"
    exit 0
fi

echo "Running tests before push..."
go test ./... || exit 1
echo "All tests passed."
